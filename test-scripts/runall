#!/bin/bash

set -eu
set -o pipefail

shopt -s nullglob

logdir=$(mktemp --directory)
pids=()

cleanup() {
	for pid in "${pids[@]}"; do
		kill "$pid" 2> /dev/null || true
	done
	rm -rf "$logdir"
}
trap cleanup EXIT INT TERM

scripts=(./test-scripts/check-*)

for script in "${scripts[@]}"; do
	name=$(basename "$script")
	"$script" > "$logdir/$name.log" 2>&1 &
	pids+=("$!")
done

failed=0

for i in "${!scripts[@]}"; do
	script="${scripts[$i]}"
	name=$(basename "$script")

	if wait "${pids[$i]}"; then
		status="PASSED"
	else
		status="FAILED"
		failed=1
	fi

	echo "************************"
	echo "$status: $script"
	echo "************************"
	echo ""
	cat "$logdir/$name.log"
done

exit $failed
